{
  "schema_version": 1,
  "purpose": "Coverage contract for Python indexed and Rust backend migration. Every bundled EVAS example testbench that the current Python backend can simulate must remain listed here until an equivalent backend parity test exists.",
  "backend_contract": {
    "current_default_backend": "python_dict",
    "migration_backends": [
      "python_indexed",
      "rust_native"
    ],
    "must_preserve": [
      "successful simulation for every listed testbench",
      "tran.csv header names and signal units",
      "strobe.txt messages when a validator consumes them",
      "validator pass/fail behavior for validator-backed cases",
      "schema and row-count sanity for schema-only cases",
      "fallback to python_dict for semantics not yet supported by the new backend"
    ]
  },
  "cases": [
