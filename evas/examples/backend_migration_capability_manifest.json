        "pwl_source",
        "clocked_adc",
        "combinational_dac",
        "reset",
        "bus_code_output"
      ],
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst_n",
        "vout",
        "dout_code"
      ],
      "validation": {
        "kind": "schema_only",
